---
pagination:
  data: currentMembers
  size: 1
  alias: member
permalink: "/members/{{ member.slug }}/"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ member.name }}"
---

<article class="member-detail">
  <a class="back" href="/">← Reading journey</a>

  <header class="member-header">
    {% if member.hasPhoto and member.photoWidths %}
      <div class="portrait">
        <img
          src="/assets/images/members/{{ member.slug }}-{{ member.photoWidths[0] }}.jpg"
          srcset="{%- for w in member.photoWidths -%}/assets/images/members/{{ member.slug }}-{{ w }}.jpg {{ w }}w{% if not loop.last %}, {% endif %}{%- endfor -%}"
          sizes="(max-width: 720px) 40vw, 240px"
          alt="{{ member.name }}" />
      </div>
    {% endif %}
    <div class="member-header-text">
      <p class="kicker">Member</p>
      <h1>{{ member.name }}</h1>
      {% if member.websites and member.websites | length %}
        <p class="member-website">
          {% for w in member.websites %}
            <a href="{{ w.url }}" rel="external noopener">{{ w.label or (w.url | replace("https://", "") | replace("http://", "") | replace("www.", "")) }}</a>{% if not loop.last %} · {% endif %}
          {% endfor %}
        </p>
      {% endif %}
      <p class="member-stats">Picked {{ member.pickedCount }} · Hosted {{ member.hostedCount }} meeting{% if member.hostedCount != 1 %}s{% endif %}</p>
    </div>
  </header>

  <section class="member-picks">
    <h2>Books picked ({{ member.pickedBooks.length }})</h2>
    {% if member.pickedBooks.length %}
      <ol class="cover-grid cover-grid--picks">
        {% for pick in member.pickedBooks %}
          {% set book = null %}
          {% for b in books %}
            {% if b.slug == pick.slug %}
              {% set book = b %}
            {% endif %}
          {% endfor %}
          <li class="cover-grid-item">
            <a href="/books/{{ pick.slug }}/">
              {% if book %}
                {% set sizes = "(max-width: 480px) 40vw, (max-width: 960px) 22vw, 160px" %}
                {% include "cover.njk" %}
              {% else %}
                <div class="cover cover--placeholder" aria-label="No cover available for {{ pick.title }}">
                  <span>{{ pick.title }}</span>
                </div>
              {% endif %}
              <p class="grid-title">{{ pick.title }}</p>
              {% if pick.year %}<p class="grid-year">{{ pick.year }}</p>{% endif %}
            </a>
          </li>
        {% endfor %}
      </ol>
    {% else %}
      <p class="empty">Hasn't picked a book yet.</p>
    {% endif %}
  </section>

  {% set memberLists = lists | listsByMember(member.slug) %}
  {% if memberLists.length %}
    <section class="member-lists">
      <h2>Lists ({{ memberLists.length }})</h2>
      <ul class="list-index">
        {% for l in memberLists %}
          <li>
            <a href="/lists/{{ l.slug }}/">{{ l.name }}</a>
            {% if l.description %}<span class="list-index-desc">{{ l.description }}</span>{% endif %}
            <span class="pick-count">{{ l.entries.length }} book{% if l.entries.length != 1 %}s{% endif %}</span>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% set memberReviews = reviews | reviewsByMember(member.slug) %}
  {% if memberReviews.length %}
    <section class="member-reviews">
      <h2>Reviews ({{ memberReviews.length }})</h2>
      <ol class="member-review-list">
        {% for r in memberReviews %}
            {% for b in books %}
              {% if b.slug == r.book %}
                <li class="member-review-row{% if r.dnf %} member-review-row--dnf{% endif %}">
                  <a class="member-review-title" href="/books/{{ b.slug }}/">{{ b.title }}</a>
                  <span class="member-review-status">
                    {% if r.dnf %}
                      DNF
                    {% elif r.rating %}
                      <span class="review-rating">{% for i in range(0, r.rating) %}★{% endfor %}{% for i in range(r.rating, 5) %}<span class="dim">★</span>{% endfor %}</span>
                    {% endif %}
                  </span>
                </li>
              {% endif %}
            {% endfor %}
        {% endfor %}
      </ol>
    </section>
  {% endif %}

  {# "To review" was a personal task list — it now lives in the member web app's Reviews tab
     (authenticated), not on this public profile. #}
</article>

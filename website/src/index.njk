---
layout: layouts/base.njk
title: ""
---

<section class="hero">
  <p class="kicker">Since {{ site.founded }}</p>
  <h1 class="hero-title">A reading journey.</h1>
  <p class="hero-lede">{{ site.description }} Scroll back through every book we've read together — newest first, all the way to the beginning.</p>
  {% if journey.totalBooks %}
    <p class="hero-stat">{{ journey.totalBooks }} books and counting.</p>
  {% endif %}
</section>

{% if journey.currentBook %}
  {% set book = journey.currentBook %}
  <section class="now-reading">
    <p class="kicker">Currently reading</p>
    <div class="now-reading-card">
      <a class="now-reading-cover" href="/books/{{ book.slug }}/" tabindex="-1" aria-hidden="true">
        {% set sizes = "(max-width: 720px) 40vw, 240px" %}
        {% include "cover.njk" %}
      </a>
      <div class="now-reading-meta">
        <h2 class="now-reading-title"><a href="/books/{{ book.slug }}/">{{ book.title }}</a></h2>
        {% if book.subtitle %}<p class="now-reading-subtitle">{{ book.subtitle }}</p>{% endif %}
        {% if book.authors.length %}<p class="now-reading-authors">by {{ book.authors | joinNames }}</p>{% endif %}
        <p class="now-reading-meeting">Meeting {{ book.meetingDate | monthYear }}</p>
        {% if book.pickerNames and book.pickerNames.length %}
          <p class="now-reading-picker">
            Picked by
            {% for i in range(0, book.pickerNames.length) %}
              {% if book.pickerSlugs[i] %}<a href="/members/{{ book.pickerSlugs[i] }}/">{{ book.pickerNames[i] }}</a>{% else %}{{ book.pickerNames[i] }}{% endif %}{% if not loop.last %} &amp; {% endif %}
            {% endfor %}
          </p>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{% if journey.upcomingBooks.length %}
  <section class="upcoming">
    <p class="kicker">Coming up</p>
    <ol class="entries">
      {% for book in journey.upcomingBooks %}
        <li class="entry entry--upcoming">
          <a class="entry-cover-link" href="/books/{{ book.slug }}/" tabindex="-1" aria-hidden="true">
            {% include "cover.njk" %}
          </a>
          <div class="entry-meta">
            <p class="entry-date">{{ book.meetingDate | monthYear }}</p>
            <h3 class="entry-title"><a href="/books/{{ book.slug }}/">{{ book.title }}</a></h3>
            {% if book.subtitle %}<p class="entry-subtitle">{{ book.subtitle }}</p>{% endif %}
            {% if book.authors.length %}<p class="entry-authors">{{ book.authors | joinNames }}</p>{% endif %}
            {% if book.pickerNames and book.pickerNames.length %}
              <p class="entry-picker">
                Picked by
                {% for i in range(0, book.pickerNames.length) %}
                  {% if book.pickerSlugs[i] %}<a href="/members/{{ book.pickerSlugs[i] }}/">{{ book.pickerNames[i] }}</a>{% else %}{{ book.pickerNames[i] }}{% endif %}{% if not loop.last %} &amp; {% endif %}
                {% endfor %}
              </p>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ol>
  </section>
{% endif %}

{% if journey.years.length %}
  <nav class="years-nav" aria-label="Jump to year">
    {% for bucket in journey.years %}
      <a href="#year-{{ bucket.year }}">{{ bucket.year }}</a>
    {% endfor %}
  </nav>

  <div class="journey">
    {% for bucket in journey.years %}
      <section class="year" id="year-{{ bucket.year }}">
        <h2 class="year-marker"><span>{{ bucket.year }}</span></h2>
        <ol class="entries">
          {% for book in bucket.books %}
            <li class="entry">
              <a class="entry-cover-link" href="/books/{{ book.slug }}/" tabindex="-1" aria-hidden="true">
                {% include "cover.njk" %}
              </a>
              <div class="entry-meta">
                <p class="entry-date">{{ book.meetingDate | monthYear }}</p>
                <h3 class="entry-title"><a href="/books/{{ book.slug }}/">{{ book.title }}</a></h3>
                {% if book.subtitle %}<p class="entry-subtitle">{{ book.subtitle }}</p>{% endif %}
                {% if book.authors.length %}<p class="entry-authors">{{ book.authors | joinNames }}</p>{% endif %}
                {% if book.pickerNames and book.pickerNames.length %}
                  <p class="entry-picker">
                    Picked by
                    {% for i in range(0, book.pickerNames.length) %}
                      {% if book.pickerSlugs[i] %}<a href="/members/{{ book.pickerSlugs[i] }}/">{{ book.pickerNames[i] }}</a>{% else %}{{ book.pickerNames[i] }}{% endif %}{% if not loop.last %} &amp; {% endif %}
                    {% endfor %}
                  </p>
                {% endif %}
                {% set bookAwards = awards | awardsForBook(book.id) %}
                {% for a in bookAwards %}
                  <p class="entry-award">{{ a.award }} · {{ a.year }}</p>
                {% endfor %}
              </div>
            </li>
          {% endfor %}
        </ol>
      </section>
    {% endfor %}
  </div>
{% else %}
  <p class="empty">The reading journey will appear here once the data layer has been fetched.</p>
{% endif %}

---
pagination:
  data: lists
  size: 1
  alias: list
permalink: "/lists/{{ list.slug }}/"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ list.name }}"
---

<article class="list-detail">
  {% if list.scope == "club" %}
    <a class="back" href="/lists/">← Lists</a>
  {% else %}
    <a class="back" href="/members/{{ list.owner }}/">← {{ list.ownerName }}</a>
  {% endif %}

  <header class="list-header">
    <p class="kicker">{% if list.scope == "club" %}Club list{% else %}{{ list.ownerName }}'s list{% endif %}</p>
    <h1>{{ list.name }}</h1>
    {% if list.description %}<p class="list-description">{{ list.description }}</p>{% endif %}
  </header>

  {% if list.entries.length %}
    <ol class="cover-grid cover-grid--list">
      {% for book in list.entries %}
        <li class="cover-grid-item">
          <a href="/books/{{ book.slug }}/">
            {% set sizes = "(max-width: 480px) 40vw, (max-width: 960px) 22vw, 160px" %}
            {% include "cover.njk" %}
            <p class="grid-title">{{ book.title }}</p>
          </a>
          {% if book.note %}<p class="list-note">{{ book.note }}</p>{% endif %}
        </li>
      {% endfor %}
    </ol>
  {% else %}
    <p class="empty">No books on this list yet.</p>
  {% endif %}
</article>

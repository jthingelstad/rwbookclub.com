# Secrets
.env

# Node / 11ty
node_modules/
_site/

# Python
.venv/
venv/
__pycache__/
*.pyc

# Oliver's private SQLite memory (class B — never committed)
*.db
*.db-wal
*.db-shm
# gzipped migration snapshots (see agent/backups/README.md)
agent/backups/*.db.gz

# Generated knowledge corpus — regenerated from the club_* tables on disk; never committed
# (kept private so it can hold sensitive context for Oliver). The site is built + deployed
# locally from this corpus to the gh-pages branch (see agent/publish.py).
corpus/data/

# Machine-generated images (covers + author portraits) — fetched from Open Library / Wikimedia
# by the enrichment loop; live locally + on the gh-pages branch. (Member photos are
# human-curated and stay committed.)
website/src/assets/images/covers/
website/src/assets/images/authors/

# Publish lock (agent/publish.py)
.publish.lock

# Oliver runtime logs (launchd captures stdout/stderr here)
agent/logs/

# Claude Code session state (CronCreate locks, etc.)
.claude/

# Scratch space for one-off imports (e.g. mailbox/Takeout dumps) — never committed
tmp/

# AGENT-TEAM per-run scratch (roles' notes; noisy). Role defs, scripts, work/, and the
# Manager's summaries/ ARE committed — only the raw run notes are ignored.
AGENT-TEAM/notes/

# One-time Airtable import cache (contains member PII: emails/mobiles) — never committed
agent/script/_airtable_cache/

# OS
.DS_Store

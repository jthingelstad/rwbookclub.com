{
  "name": "rwbookclub-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the R/W Book Club: the website, the knowledge corpus, and the Discord agent (Oliver).",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "website"
  ],
  "scripts": {
    "build": "npm run build -w website",
    "test": "npm run test -w website",
    "serve": "npm run serve -w website",
    "clean": "npm run clean -w website",
    "covers": "uv run --locked python -m corpus.images",
    "deploy": "uv run --locked python -m agent.publish"
  }
}

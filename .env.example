# Shared secrets for the monorepo. Copy to .env and fill in real values.
# .env is git-ignored — never commit it.

# Airtable — cold backup only (the corpus is canonical in Git; used for re-import)
AIRTABLE_BASE_ID=
AIRTABLE_PAT=

# Discord — Oliver, the agent (agent/)
DISCORD_BOT_TOKEN=
DISCORD_BOT_ID=
DISCORD_SERVER_ID=
DISCORD_ASK_OLIVER_CHANNEL_ID=
DISCORD_MAIN_CHANNEL_ID=     # where Oliver posts proactive reminders/nudges (scheduler no-ops if unset)
DISCORD_BOOK_TALK_CHANNEL_ID=  # monitored like #general: passive logging + replies only when addressed
DISCORD_OLIVER_LOG_WEBHOOK_URL=  # webhook for #oliver-log activity posts
DISCORD_ADMIN_USER_ID=

# Claude API — Oliver's brain
ANTHROPIC_API_KEY=

# Oliver runtime (agent/) — optional
# OLIVER_GIT_PUSH=1     # set to 0 to commit reviews locally without pushing (dev/testing)
# OLIVER_DB_PATH=       # SQLite memory path (default: agent/oliver.db)
# CLUB_TIMEZONE=America/Chicago

# Oliver email via Fastmail JMAP — optional
FASTMAIL_JMAP_TOKEN=
# FASTMAIL_JMAP_SESSION_URL=https://api.fastmail.com/jmap/session
# OLIVER_EMAIL_ADDRESS=oliver@rwbookclub.com
# OLIVER_EMAIL_INBOX_PARENT=Inbox
# OLIVER_EMAIL_INBOX_FOLDER=Oliver
# OLIVER_EMAIL_SENT_PARENT=Sent
# OLIVER_EMAIL_SENT_FOLDER=Oliver
# OLIVER_EMAIL_POLL_SECONDS=120
# OLIVER_EMAIL_MAX_PER_POLL=5
# OLIVER_EMAIL_HTML_ENABLED=1
# TINYLYTICS_SITE_ID=
# TINYLYTICS_SITE_ID_NUMERIC=
# TINYLYTICS_API_KEY=       # read-only is sufficient for email-open sync
# TINYLYTICS_SYNC_SECONDS=600

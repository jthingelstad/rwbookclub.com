# Shared secrets for the monorepo. Copy to .env and fill in real values.
# .env is git-ignored — never commit it.

# Airtable is retired and no longer read by any code. The club_* SQLite tables are
# authoritative; the one-time re-seed importer (`python -m agent.script.import_airtable`)
# reads the on-disk snapshot under agent/script/_airtable_cache/, not the API — no creds.

# Discord — Oliver, the agent (agent/)
DISCORD_BOT_TOKEN=
DISCORD_BOT_ID=
DISCORD_SERVER_ID=
DISCORD_ASK_OLIVER_CHANNEL_ID=
DISCORD_MAIN_CHANNEL_ID=     # where Oliver posts proactive reminders/nudges (scheduler no-ops if unset)
DISCORD_BOOK_TALK_CHANNEL_ID=  # monitored like #general: passive logging + replies only when addressed
DISCORD_OLIVER_LOG_WEBHOOK_URL=  # webhook for #oliver-log activity posts
DISCORD_ADMIN_USER_ID=

# Claude API — Oliver's brain
ANTHROPIC_API_KEY=

# Oliver runtime (agent/) — optional
# OLIVER_DB_PATH=       # SQLite memory path (default: agent/oliver.db)
# OLIVER_CORPUS_DIR=    # corpus dir override (tests redirect to a temp dir)
# CLUB_TIMEZONE=America/Chicago
# OLIVER_ENRICH_ON_WRITE=1   # set 0 to skip inline enrichment on add-book (tests run offline)
# OLIVER_REFLECTION_ENABLED=1  # weekly reflective-memory pass (internal); set 0 to disable

# Local site publish to gh-pages (agent/publish.py) — optional; sensible defaults
# OLIVER_GIT_AUTHOR_NAME=Oliver (RWBC bot)
# OLIVER_GIT_AUTHOR_EMAIL=oliver@rwbookclub.com
# SITE_URL=https://rwbookclub.com                   # public site origin; self-heal reads /next.json here

# Member web app (in-process aiohttp server, exposed via Tailscale Funnel) — optional
# WEBAPP_PORT=8765                                  # loopback port; Funnel maps public 443 → here
# WEBAPP_BASE_URL=https://otto.tail09aaf9.ts.net    # public Funnel origin (no trailing slash)
# WEBAPP_SECRET=                                    # SET IN PROD: dedicated key for signing session
#                                                   # cookies + CSRF tokens (any strong random string).
#                                                   # Unset → falls back to the Discord bot token.

# Oliver email via Fastmail JMAP — optional
FASTMAIL_JMAP_TOKEN=
# BOOK_CLUB_MAILING_LIST_ADDRESS=   # the club mailing list Oliver reads/answers
# CLUB_EMAIL_CADENCE_ENABLED=0      # 1 enables club-wide cadence email blasts
# FASTMAIL_JMAP_SESSION_URL=https://api.fastmail.com/jmap/session
# OLIVER_EMAIL_ADDRESS=oliver@rwbookclub.com
# OLIVER_EMAIL_INBOX_PARENT=Inbox
# OLIVER_EMAIL_INBOX_FOLDER=Oliver
# OLIVER_EMAIL_SENT_PARENT=Sent
# OLIVER_EMAIL_SENT_FOLDER=Oliver
# OLIVER_EMAIL_POLL_SECONDS=120
# OLIVER_EMAIL_MAX_PER_POLL=5
# OLIVER_EMAIL_HTML_ENABLED=1
